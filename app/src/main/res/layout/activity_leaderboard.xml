<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dark_gradient">

    <!-- header -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="#80000000"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@color/text_primary"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Weekly Champions"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <ImageButton
            android:id="@+id/btnShare"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_share"
            app:tint="@color/text_primary"/>
    </LinearLayout>

    <!-- podium -->
    <LinearLayout
        android:id="@+id/podiumLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/headerLayout">

        <!-- second place -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🥈"
                android:textSize="32sp"/>

            <ImageView
                android:id="@+id/iv2ndPlace"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/rank_circle"
                android:padding="4dp"
                android:src="@android:drawable/ic_menu_myplaces"/>

            <TextView
                android:id="@+id/tv2ndName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lord Alene"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:maxLines="2"
                android:gravity="center"/>

            <TextView
                android:id="@+id/tv2ndSteps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="◆ 84,787 Steps"
                android:textColor="@color/secondary_green"
                android:textSize="11sp"/>
        </LinearLayout>

        <!-- first place -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👑"
                android:textSize="40sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏆"
                android:textSize="32sp"/>

            <ImageView
                android:id="@+id/iv1stPlace"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/rank_circle"
                android:padding="4dp"
                android:src="@android:drawable/ic_menu_myplaces"/>

            <TextView
                android:id="@+id/tv1stName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MyWarrior"
                android:textColor="@color/text_gold"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tv1stSteps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="◆ 96,239 Steps"
                android:textColor="@color/secondary_green"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- third place -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="48dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🥉"
                android:textSize="28sp"/>

            <ImageView
                android:id="@+id/iv3rdPlace"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/rank_circle"
                android:padding="4dp"
                android:src="@android:drawable/ic_menu_myplaces"/>

            <TextView
                android:id="@+id/tv3rdName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lord Garl"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:maxLines="2"
                android:gravity="center"/>

            <TextView
                android:id="@+id/tv3rdSteps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="◆ 82,139 Steps"
                android:textColor="@color/secondary_green"
                android:textSize="11sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- other ranks -->
    <TextView
        android:id="@+id/tvOtherRanks"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⚔ OTHER RANKS ⚔"
        android:textColor="@color/text_gold"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center"
        android:background="#40000000"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/podiumLayout"/>

    <!-- rankings list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvLeaderboard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvOtherRanks"
        app:layout_constraintBottom_toTopOf="@id/buttonsLayout"/>

    <!-- buttons -->
    <LinearLayout
        android:id="@+id/buttonsLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation">

        <Button
            android:id="@+id/btnChampions"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="CHAMPIONS"
            style="@style/PrimaryButton"/>

        <Button
            android:id="@+id/btnMainMenu"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:text="MAIN MENU"
            style="@style/SecondaryButton"/>
    </LinearLayout>

    <!-- bottom nav -->
    <include 
        android:id="@+id/bottomNavigation"
        layout="@layout/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
