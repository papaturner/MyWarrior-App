<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_golden_gradient"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <!-- icon -->
        <ImageView
            android:id="@+id/ivWarriorIcon"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@mipmap/ic_launcher"
            android:scaleType="fitCenter"
            android:layout_marginTop="40dp"
            android:contentDescription="Warrior"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- title -->
        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome to\nFitness Warrior"
            android:textColor="@color/text_dark"
            android:textSize="32sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/ivWarriorIcon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- subtitle -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="#80FFFFFF"
            app:cardCornerRadius="16dp"
            app:layout_constraintTop_toBottomOf="@id/tvWelcome">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Power up your Warrior with real-world free weight workouts and battle evil creatures!"
                android:textColor="@color/text_dark"
                android:textSize="16sp"
                android:gravity="center"
                android:padding="20dp"/>
        </androidx.cardview.widget.CardView>

        <!-- username -->
        <EditText
            android:id="@+id/etUsername"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/edit_text_background"
            android:hint="Enter your warrior name"
            android:textColorHint="#808080"
            android:textColor="@color/text_dark"
            android:inputType="text"
            android:maxLines="1"
            android:gravity="center"
            android:textSize="18sp"
            app:layout_constraintTop_toBottomOf="@id/cardSubtitle"/>

        <!-- password -->
        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/edit_text_background"
            android:hint="Password"
            android:textColorHint="#808080"
            android:textColor="@color/text_dark"
            android:inputType="textPassword"
            android:maxLines="1"
            android:gravity="center"
            android:textSize="18sp"
            app:layout_constraintTop_toBottomOf="@id/etUsername"/>

        <!-- login button -->
        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:text="BEGIN ADVENTURE ⚔️"
            android:textColor="@color/text_dark"
            android:textSize="18sp"
            android:textStyle="bold"
            style="@style/SecondaryButton"
            app:layout_constraintTop_toBottomOf="@id/etPassword"/>

        <!-- bottom links -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="48dp"
            app:layout_constraintTop_toBottomOf="@id/btnLogin">

            <TextView
                android:id="@+id/tvCreateAccount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Create account"
                android:textColor="@color/text_dark"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/tvLoginLink"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Login"
                android:textColor="@color/text_dark"
                android:textSize="14sp"
                android:gravity="end"/>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
