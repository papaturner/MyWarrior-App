<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dark_gradient">

    <!-- gold display -->
    <TextView
        android:id="@+id/tvGold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="325 ⚡"
        android:textColor="@color/text_gold"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_margin="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- back button -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_margin="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_revert"
        android:contentDescription="Back"
        app:tint="@color/text_primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="YE OLDE\nARMORY"
        android:textColor="@color/text_secondary"
        android:textSize="28sp"
        android:textStyle="bold"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- potions -->
    <Button
        android:id="@+id/btnPotions"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="32dp"
        android:text="POTIONS"
        android:textColor="#2E7D32"
        android:textSize="32sp"
        android:textStyle="bold|italic"
        android:background="@drawable/quest_card_background"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"/>

    <!-- shields -->
    <Button
        android:id="@+id/btnShields"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="16dp"
        android:text="SHIELDS"
        android:textColor="#7B1FA2"
        android:textSize="32sp"
        android:textStyle="bold|italic"
        android:background="@drawable/quest_card_background"
        app:layout_constraintTop_toBottomOf="@id/btnPotions"/>

    <!-- weapons -->
    <Button
        android:id="@+id/btnWeapons"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="16dp"
        android:text="WEAPONS"
        android:textColor="#C62828"
        android:textSize="32sp"
        android:textStyle="bold|italic"
        android:background="@drawable/quest_card_background"
        app:layout_constraintTop_toBottomOf="@id/btnShields"/>

    <!-- bottom nav -->
    <include 
        layout="@layout/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
