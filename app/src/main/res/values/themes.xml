<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- app theme -->
    <style name="Theme.FitnessWarrior" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_yellow</item>
        <item name="colorPrimaryDark">@color/brand_brown</item>
        <item name="colorAccent">@color/brand_gold</item>
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="android:navigationBarColor">@color/background_dark</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <!-- button style override -->
        <item name="materialButtonStyle">@style/Widget.FitnessWarrior.Button</item>
    </style>

    <!-- base button -->
    <style name="Widget.FitnessWarrior.Button" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="backgroundTint">@null</item>
        <item name="android:backgroundTint">@null</item>
        <item name="rippleColor">#40000000</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <!-- splash theme -->
    <style name="Theme.Splash" parent="Theme.FitnessWarrior">
        <item name="android:windowBackground">#0D1020</item>
        <item name="android:statusBarColor">#0D1020</item>
        <item name="android:navigationBarColor">#0D1020</item>
    </style>

    <!-- onboarding theme -->
    <style name="Theme.Golden" parent="Theme.FitnessWarrior">
        <item name="android:windowBackground">@color/brand_yellow</item>
        <item name="android:textColorPrimary">@color/text_dark</item>
    </style>

    <!-- button styles -->
    <style name="PrimaryButton" parent="Widget.FitnessWarrior.Button">
        <item name="android:background">@drawable/btn_primary</item>
        <item name="backgroundTint">@null</item>
        <item name="android:textColor">#1A1A00</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:gravity">center</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="SecondaryButton" parent="Widget.FitnessWarrior.Button">
        <item name="android:background">@drawable/btn_secondary</item>
        <item name="backgroundTint">@null</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:gravity">center</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="DangerButton" parent="Widget.FitnessWarrior.Button">
        <item name="android:background">@drawable/btn_danger</item>
        <item name="backgroundTint">@null</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:gravity">center</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <!-- card styles -->
    <style name="GameCard">
        <item name="android:background">@drawable/card_background</item>
        <item name="android:padding">16dp</item>
        <item name="android:elevation">4dp</item>
    </style>

    <style name="QuestCard">
        <item name="android:background">@drawable/quest_card_background</item>
        <item name="android:padding">16dp</item>
    </style>

    <!-- text styles -->
    <style name="DisplayTextXL">
        <item name="android:textSize">48sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="DisplayTextLG">
        <item name="android:textSize">36sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="DisplayTextMD">
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="DisplayTextSM">
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="BodyText">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="GoldText">
        <item name="android:textColor">@color/text_gold</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
